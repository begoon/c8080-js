{
  "name": "c8080-js",
  "version": "0.0.1",
  "description": "C compiler for Intel 8080, TypeScript port of c8080",
  "type": "module",
  "module": "src/cli.ts",
  "bin": {
    "c8080": "bin/c8080.ts"
  },
  "scripts": {
    "test": "bun test",
    "build": "bun build --compile --target=bun-darwin-arm64 bin/c8080.ts --outfile dist/c8080",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "asm8080": "^1.0.26"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
