{
  "name": "c8080",
  "version": "0.1.0",
  "description": "C compiler for Intel 8080 / КР580ВМ80А — TypeScript port of Aleksey Morozov's c8080",
  "type": "module",
  "bin": {
    "c8080": "dist/c8080.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build bin/c8080.ts --target=node --format=esm --external=asm8080 --outfile=dist/c8080.js",
    "build:playground": "bun build docs/playground.ts --target=browser --format=esm --outfile=docs/playground.js",
    "serve:playground": "bun run build:playground && cd docs && python3 -m http.server 8733",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "asm8080": "^1.0.26"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "8080",
    "i8080",
    "intel-8080",
    "retro",
    "compiler",
    "cp/m",
    "rk86",
    "radio-86rk",
    "c"
  ],
  "license": "GPL-3.0"
}
